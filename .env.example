# ==========================================================
# AgenThink standalone (.env.example)
# Copy to .env and fill values. Never commit real secrets.
# ==========================================================

LLM_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key
# GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

OPENAI_API_KEY=your_openai_or_local_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

LOCAL_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
VLLM_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_MODEL=llama3.2
LOCAL_OPENAI_API_KEY=ollama

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=14
AUTH_REQUIRED=true

SEED_DEMO_USER=true
DEMO_USER_EMAIL=demo@local
DEMO_USER_PASSWORD=change-me

# Local RAG (Tri thức) — stored under RAG_DATA_DIR
RAG_DATA_DIR=./data/rag
RAG_PROJECT_ID=agentthink_default
RAG_EMBED_MODEL=text-embedding-004

# SearXNG (web_search). Compose overrides to http://searxng:8080.
# Local API + Compose SearXNG only: SEARXNG_URL=http://localhost:8080
SEARXNG_URL=

DATABASE_URL=sqlite:///chat_memory.db
ENABLE_STREAMING=true
ENABLE_MULTIMODAL=true
